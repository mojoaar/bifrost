# Bifröst environment variables
#
# Copy this file to `.env` and fill in the values.
# Never commit your real `.env` file.

# REQUIRED — JSON Web Token signing secrets.
# Bifröst refuses to start unless both are set.
# Generate a strong value for each, e.g.: openssl rand -hex 64
BIFROST_JWT_SECRET=
BIFROST_JWT_REFRESH_SECRET=

# Database location (SQLite by default).
# Prefix a file path with `file:`.
DATABASE_URL=file:./data/bifrost.db

# Content directory (markdown posts, pages, media). Defaults to ./content
# BIFROST_CONTENT_DIR=content

# Public site URL, used for absolute links in metadata, RSS and sitemap.
# Falls back to http://localhost:3000 when unset.
# BIFROST_SITE_URL=https://example.com

# Optional Git token for pushing content history to a remote.
# Can also be set from the admin Settings UI (git.token).
# BIFROST_GIT_TOKEN=

# Set to "false" to allow non-HTTPS cookies (e.g. local network deploys).
# Defaults to secure cookies except in development.
# BIFROST_SECURE_COOKIES=true
